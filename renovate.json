{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": [
    "main"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "0-core/**/*.yaml",
      "1-data/**/*.yaml",
      "2-platform/**/*.yaml",
      "3-apps/**/*.yaml"
    ]
  },
  "packageRules": [
    {
      "description": "자동 merge",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "PR만 생성",
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "PR + breaking",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["breaking"]
    },
    {
      "description": "CI 인프라 무시",
      "matchPackageNames": ["my-custom-app"],
      "enabled": false
    },
    {
      "description": "자체 빌드 이미지 무시 (Flux Image Automation 관리)",
      "matchPackageNames": ["my-custom-app"],
      "enabled": false
    }
  ]
}
