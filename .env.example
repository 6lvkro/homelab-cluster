# Homelab 환경 변수 템플릿
# 비민감 설정: .env.config (git에 커밋, CI에서 사용)
# 시크릿: Infisical (self-hosted, CI에서 fetch)

# ──── 공통 ────────────────────────
TZ=Asia/Seoul
DEFAULT_USERNAME=myuser

# ──── 노드 ────────────────────────
NODE_MASTER=node1
NODE_MASTER_IP=192.168.0.101
NODE_IOT=node1
NODE_IOT_IP=192.168.0.101
NODE_STORAGE=node2
NODE_STORAGE_IP=192.168.0.102
NODE_COMPUTE=node3
NODE_COMPUTE_IP=192.168.0.103

# ──── 네트워크 ────────────────────────
DOMAIN_EXTERNAL=example.com
DOMAIN_LAN=hl.lan
LAN_SUBNET=192.168.0.0/24
LAN_BROADCAST=192.168.0.255
LB_RANGE=192.168.0.240-192.168.0.254
LB_TRAEFIK_IP=192.168.0.240
LB_ADGUARD_IP=192.168.0.241
LB_POSTGRES_IP=192.168.0.242
LB_SAMBA_IP=192.168.0.243
LB_GITEA_IP=192.168.0.244

# ──── 서브도메인 ────────────────────────
SUB_ADGUARD=adguard
SUB_GITEA=git
SUB_GRAFANA=grafana
SUB_HOMEASSISTANT=ha
SUB_INFISICAL=infisical
SUB_OAUTH2_PROXY=oauth
SUB_OLLAMA=ollama
SUB_OPENWEBUI=chat
SUB_POCKET_ID=id
SUB_TRAEFIK=traefik
SUB_Z2M=z2m

# ──── Gitea / 레지스트리 ────────────────────────
GITEA_URL=http://gitea:3000
REGISTRY=git.hl.lan/myuser

# ──── Infisical ────────────────────────
INFISICAL_PROJECT_SLUG=my-project-slug

# ──── 경로 ────────────────────────
PATH_NFS=/mnt/k8s-nfs
PATH_ZIGBEE_USB=/dev/serial/by-id/your-zigbee-adapter

# ──── 백업 ────────────────────────
B2_VELERO_BUCKET=my-velero-bucket
B2_RCLONE_BUCKET=my-rclone-bucket
B2_REGION=us-east-001
B2_ENDPOINT=https://s3.us-east-001.backblazeb2.com

# ──── Pocket ID OIDC Client ID ────────────────────────
POCKET_ID_CLIENT_ID_GRAFANA=changeme          # Grafana OIDC client ID
POCKET_ID_CLIENT_ID_OAUTH2_PROXY=changeme     # OAuth2-Proxy OIDC client ID
POCKET_ID_CLIENT_ID_OPENWEBUI=changeme        # Open-WebUI OIDC client ID


# ════════════════════════════════════════════
#  시크릿 (Infisical에서 관리)
#  WARNING: .env.config에 직접 쓰지 않으며 아래는 참조용
# ════════════════════════════════════════════

# ──── 공통 ────────────────────────
DEFAULT_PASSWORD=changeme                     # 공통 비밀번호 (Grafana, Samba 등)

# ──── 서비스 토큰 ────────────────────────
CLOUDFLARE_TOKEN=changeme                     # Cloudflare Tunnel 토큰
GITEA_RUNNER_REGISTRATION_TOKEN=changeme      # Gitea Actions runner 등록 토큰
GITEA_TOKEN=changeme                          # Gitea 레지스트리 토큰
NTFY_TOPIC=changeme                           # Ntfy.sh 푸시 알림 토픽

# ──── 백업 ────────────────────────
B2_KEY_ID=changeme                            # B2 Application Key ID
B2_APPLICATION_KEY=changeme                   # B2 Application Key

# ──── DB 비밀번호 ────────────────────────
DB_PASSWORD_POSTGRES=changeme                 # PostgreSQL 관리자 비밀번호
DB_PASSWORD_INFISICAL=changeme                # Infisical DB 비밀번호
DB_PASSWORD_GRAFANA=changeme                  # Grafana DB 비밀번호
DB_PASSWORD_OPENWEBUI=changeme                # Open-WebUI DB 비밀번호

# ──── Pocket ID ────────────────────────
POCKET_ID_ENCRYPTION_KEY=changeme             # Pocket ID 암호화 키
POCKET_ID_OIDC_GRAFANA=changeme               # Grafana OIDC client secret
POCKET_ID_OIDC_OAUTH2_PROXY=changeme          # OAuth2-Proxy OIDC client secret
POCKET_ID_OIDC_OPENWEBUI=changeme             # Open-WebUI OIDC client secret
OAUTH2_PROXY_COOKIE_SECRET=changeme           # OAuth2-Proxy cookie encryption key

